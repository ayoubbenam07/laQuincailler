// schema.prisma

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CASHIER
}

enum Category {
  TOOLS
  PLUMBING
  ELECTRICAL
  HARDWARE
  PAINT
  MATERIALS
  OTHER
}

enum MeasureUnit {
  PIECE
  KG
  METER
  LITER
  BOX
  PACK
}

model User {
  id       String @id @default(uuid()) @db.Uuid
  username String @unique
  password String // Hashed password
  role     Role   @default(CASHIER)
  sales    Sale[]

  syncStatus String   @default("pending")
  isDeleted  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Client {
  id           String        @id @default(uuid()) @db.Uuid
  name         String
  phone        String?
  debt         Float         @default(0.0) // Tracks the total unpaid amount
  sales        Sale[]
  debtPayments DebtPayment[]

  syncStatus String   @default("pending")
  isDeleted  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Product {
  id         String @id @default(uuid()) @db.Uuid
  barcode    String @unique
  name       String
  basePrice  Float
  addition   Float
  finalPrice Float
  stock      Float
  minStock   Float  @default(10)

  // New Optional Fields
  category    Category?
  weight      Float?
  color       String?
  measureUnit MeasureUnit?

  saleItems SaleItem[]

  syncStatus String   @default("pending")
  isDeleted  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Sale {
  id        String @id @default(uuid()) @db.Uuid
  cashierId String @db.Uuid
  cashier   User   @relation(fields: [cashierId], references: [id])

  // Client relation for debt tracking
  clientId String? @db.Uuid
  client   Client? @relation(fields: [clientId], references: [id])

  totalAmount Float
  amountPaid  Float // How much the client actually handed to the cashier

  items SaleItem[]

  syncStatus String   @default("pending")
  isDeleted  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SaleItem {
  id        String  @id @default(uuid()) @db.Uuid
  saleId    String  @db.Uuid
  sale      Sale    @relation(fields: [saleId], references: [id])
  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id])
  quantity  Float
  priceSold Float

  syncStatus String   @default("pending")
  isDeleted  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model DebtPayment {
  id       String @id @default(uuid()) @db.Uuid
  clientId String @db.Uuid
  client   Client @relation(fields: [clientId], references: [id])
  amount   Float

  syncStatus String   @default("pending")
  isDeleted  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
